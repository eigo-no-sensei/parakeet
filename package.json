{
  "name": "transcribe-desktop",
  "version": "1.0.0",
  "description": "WebGPU-powered speech transcription with Parakeet & Cohere models",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "onnxruntime-web": "^1.20.0",
    "@huggingface/transformers": "^3.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "axios": "^1.7.0",
    "electron-store": "^8.2.0",
    "wavefile": "^11.0.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.transcribe.desktop",
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}
